{
  "name": "unisouq",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "frontend",
    "backend",
    "bot"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build:shared": "npm run build -w shared",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:migrate:prod": "npm run db:migrate:prod -w backend",
    "db:seed": "npm run db:seed -w backend",
    "register-webhook": "npm run register-webhook -w bot",
    "deploy:frontend": "cd frontend && npx vercel --prod"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^5.22.0",
    "pg": "^8.20.0"
  }
}
