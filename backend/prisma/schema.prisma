generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum ReputationTier {
  NEW
  TRUSTED
  EXPERT
  ELITE
}

enum TransactionType {
  GIFT_PURCHASE
  PLUS_SUBSCRIPTION
  THEME_PURCHASE
  SOCIAL_BOOST
  AI_USAGE
  REFERRAL_BONUS
  TON_WITHDRAWAL
  TON_DEPOSIT
}

enum Currency {
  STARS
  TON
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  SENT
  FAILED
}

enum GiftRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
}

enum PurchaseKind {
  GIFT
  THEME
  PLUS
  SOCIAL_BOOST
}

enum PostStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

// ─── Core ────────────────────────────────────────────

model User {
  id                String         @id @default(uuid())
  telegramId        BigInt         @unique
  username          String?
  firstName         String
  lastName          String?
  avatarUrl         String?
  role              UserRole       @default(USER)

  // Balances
  starsBalance      Int            @default(0)
  tonBalance        Float          @default(0)
  totalEarnedStars  Int            @default(0)

  // Reputation (earned from social activity + gift ownership)
  reputationScore   Int            @default(0)
  reputationTier    ReputationTier @default(NEW)

  // Unisouq Plus — denormalized "active until" cached from PlusSubscription
  premiumBadgeUntil DateTime?

  // Selected theme (null = default dark)
  activeThemeId     String?
  activeTheme       Theme?         @relation("ActiveTheme", fields: [activeThemeId], references: [id])

  // Wallet + settings
  tonAddress        String?
  language          String         @default("en")
  theme             String         @default("dark")

  // Referral
  referralCode      String         @unique @default(cuid())
  referredById      String?
  referredBy        User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referrals         User[]         @relation("UserReferrals")
  referralBonusClaimedAt DateTime?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  transactions      Transaction[]
  withdrawals       WithdrawalRequest[]
  purchases         Purchase[]
  giftsOwned        UserGift[]
  themesOwned       UserTheme[]
  plusSubs          PlusSubscription[]
  posts             Post[]
  postLikes         PostLike[]
  postComments      PostComment[]

  @@index([reputationTier])
}

// ─── Gifts (NFT collectibles minted by admin) ───────

model Gift {
  id             String      @id @default(uuid())
  name           String
  description    String
  imageUrl       String
  rarity         GiftRarity  @default(COMMON)
  priceStars     Int?
  priceTon       Float?
  editionSize    Int?        // null = unlimited
  editionMinted  Int         @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  owners         UserGift[]

  @@index([isActive, rarity])
}

model UserGift {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  giftId    String
  gift      Gift     @relation(fields: [giftId], references: [id])
  serialNo  Int      // per-gift edition number
  acquiredAt DateTime @default(now())

  @@unique([giftId, serialNo])
  @@index([userId])
}

// ─── Themes (cosmetic palettes) ─────────────────────

model Theme {
  id          String   @id @default(uuid())
  name        String
  description String?
  previewUrl  String?
  palette     Json     // { bg, surface, surface2, border, accent, teal, gold, text, textMuted }
  priceStars  Int?
  priceTon    Float?
  plusOnly    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owners      UserTheme[]
  activeFor   User[]    @relation("ActiveTheme")

  @@index([isActive])
}

model UserTheme {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeId   String
  theme     Theme    @relation(fields: [themeId], references: [id])
  acquiredAt DateTime @default(now())

  @@unique([userId, themeId])
}

// ─── Unisouq Plus ───────────────────────────────────

model PlusPlan {
  id           String   @id @default(uuid())
  name         String   // "Weekly", "Monthly", "Yearly"
  durationDays Int
  priceStars   Int?
  priceTon     Float?
  priceFiat    Float?   // in USD cents
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subs         PlusSubscription[]
}

model PlusSubscription {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  plan        PlusPlan @relation(fields: [planId], references: [id])
  startsAt    DateTime @default(now())
  endsAt      DateTime
  createdAt   DateTime @default(now())

  @@index([userId, endsAt])
}

// ─── Social ─────────────────────────────────────────

model Post {
  id         String     @id @default(uuid())
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  imageUrl   String?
  status     PostStatus @default(PUBLISHED)
  likeCount  Int        @default(0)
  commentCount Int      @default(0)
  boostedUntil DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  likes      PostLike[]
  comments   PostComment[]

  @@index([status, createdAt])
  @@index([boostedUntil])
}

model PostLike {
  id       String   @id @default(uuid())
  postId   String
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PostComment {
  id       String   @id @default(uuid())
  postId   String
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body     String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

// ─── Payment routing ────────────────────────────────

// Unified Stars/TON purchase log. Any Telegram Stars invoice created by
// the app (gift, theme, plus, boost) gets a Purchase row and is resolved
// by payload when the webhook fires successful_payment.
model Purchase {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  kind             PurchaseKind
  status           PurchaseStatus @default(PENDING)
  currency         Currency       @default(STARS)
  amount           Float
  invoicePayload   String         @unique
  telegramChargeId String?
  // Target ids — only the one matching `kind` is filled.
  giftId           String?
  themeId          String?
  plusPlanId       String?
  postId           String?
  meta             Json?
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([userId, kind])
  @@index([status, createdAt])
}

// ─── Wallet ─────────────────────────────────────────

model Transaction {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])

  type          TransactionType
  currency      Currency
  amount        Float           // positive = credit, negative = debit
  balanceAfter  Float

  meta          Json?
  createdAt     DateTime        @default(now())

  @@index([userId, createdAt])
}

model WithdrawalRequest {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  tonAddress     String
  grossAmount    Float
  feeAmount      Float
  netAmount      Float
  status         WithdrawalStatus @default(PENDING)
  idempotencyKey String
  externalTxId   String?
  failureReason  String?
  approvedAt     DateTime?
  sentAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([userId, idempotencyKey])
  @@index([status, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
