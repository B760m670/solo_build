generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  SENT
  FAILED
}

model User {
  id            String        @id @default(uuid())
  telegramId    BigInt        @unique
  username      String?
  firstName     String
  lastName      String?
  avatarUrl     String?
  isPremium     Boolean       @default(false)
  premiumExpiry DateTime?
  role          UserRole      @default(USER)
  brbBalance    Float         @default(0)
  totalEarned   Float         @default(0)
  tonWallet     String?
  referralCode  String        @unique @default(cuid())
  referredBy    String?
  referralCount Int           @default(0)
  referralEarned Float        @default(0)
  reputationScore Int         @default(50)
  trustLevel      String      @default("STANDARD")
  language      String        @default("en")
  theme         String        @default("dark")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tasks         UserTask[]
  transactions  Transaction[]
  listings      Listing[]
  orders        Order[]
  subscription  Subscription?
  withdrawals   WithdrawalRequest[]
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String
  category    String
  verificationType String @default("MANUAL")
  verificationPolicy Json?
  reward      Float
  timeMinutes Int
  brand       String
  sponsorName String?
  sponsorType String?
  sponsorBudgetCurrency String?
  sponsorBudgetAmount   Float?
  sponsorBudgetSpent    Float        @default(0)
  kpiName     String?
  kpiTarget   Float?
  kpiUnit     String?
  audienceRules Json?
  cooldownSeconds Int      @default(0)
  minReputation Int        @default(0)
  minAccountAgeDays Int    @default(0)
  brandLogo   String?
  isActive    Boolean    @default(true)
  totalSlots  Int        @default(100)
  filledSlots Int        @default(0)
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  userTasks   UserTask[]
}

model UserTask {
  id          String    @id @default(uuid())
  userId      String
  taskId      String
  status      String    @default("PENDING")
  proof       String?
  proofData   Json?
  deviceFingerprint String?
  riskScore   Int       @default(0)
  riskFlags   String[]  @default([])
  submittedAt DateTime?
  reviewedAt  DateTime?
  reviewNote  String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  task        Task      @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
}

model Listing {
  id          String   @id @default(uuid())
  sellerId    String
  title       String
  description String
  price       Float
  category    String
  images      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  seller      User     @relation(fields: [sellerId], references: [id])
  orders      Order[]
}

model Order {
  id         String   @id @default(uuid())
  buyerId    String
  listingId  String
  amount     Float
  commission Float
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  buyer      User     @relation(fields: [buyerId], references: [id])
  listing    Listing  @relation(fields: [listingId], references: [id])
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  type          String
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  meta          Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model WithdrawalRequest {
  id             String           @id @default(uuid())
  userId         String
  tonAddress     String
  grossAmount    Float
  feeAmount      Float
  netAmount      Float
  status         WithdrawalStatus @default(PENDING)
  idempotencyKey String
  externalTxId   String?
  failureReason  String?
  approvedAt     DateTime?
  sentAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([status, createdAt])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  plan      String   @default("PREMIUM")
  startsAt  DateTime @default(now())
  expiresAt DateTime
  isActive  Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id])
}
